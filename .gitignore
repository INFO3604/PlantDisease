# =========================
# DATA (ignore contents)
# =========================
data/raw/*
data/interim/*
data/processed/*
data/splits/*
data/demo_input/*
data/demo_output/*
data/features/*
data/preprocessed_output/*

# =========================
# MODELS
# =========================

# Ignore everything in models by default
models/*

# Allow specific model folders
!models/exports/
!models/rf_ensemble/

# Allow files inside exports (trained models)
!models/exports/*.pkl
!models/exports/*.json

# ❌ EXCLUDE LARGE MODELS (GitHub limit fix)
models/exports/random_forest.pkl
models/exports/catboost.pkl

# Allow RF ensemble models
!models/rf_ensemble/*.pkl

# Keep structure
!models/exports/.gitkeep
!models/rf_ensemble/.gitkeep

# =========================
# EXPORTS
# =========================
exports/*

# =========================
# KEEP EMPTY DIRS
# =========================
!**/.gitkeep

# =========================
# ENVIRONMENT
# =========================
.env
.env.local

__pycache__/
*.py[cod]
*$py.class
*.so
.Python

build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# =========================
# VIRTUAL ENV
# =========================
venv/
ENV/
env/

# =========================
# IDE
